# CampusConnect Environment Configuration

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE - MySQL Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# MySQL Host (your laptop IP or localhost)
DB_HOST=localhost

# MySQL Port (default: 3306)
DB_PORT=3306

# MySQL Username
DB_USER=root

# MySQL Password
DB_PASSWORD=

# MySQL Database Name
DB_NAME=campusconnect

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════════════════════

# Server port
PORT=3000

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# WHATSAPP NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable WhatsApp notifications
WHATSAPP_ENABLED=true

# Service type: 'twilio' or 'mock'
# 'twilio' - Send real WhatsApp messages via Twilio
# 'mock' - Log messages to console (development)
WHATSAPP_SERVICE_TYPE=mock

# Twilio Configuration (required if WHATSAPP_SERVICE_TYPE=twilio)
# Get these from https://www.twilio.com/console

# Twilio Account SID (e.g., ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token (keep secret!)
TWILIO_AUTH_TOKEN=

# WhatsApp Sender Phone Number (must be registered with Twilio, format: +91xxxxxxxxxx)
WHATSAPP_SENDER_NUMBER=

# ═══════════════════════════════════════════════════════════════════════════════
# EXAMPLE SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# 1. To use MOCK mode (for development):
#    - Set WHATSAPP_ENABLED=true
#    - Set WHATSAPP_SERVICE_TYPE=mock
#    - Messages will be logged to console
#
# 2. To use TWILIO mode (for production):
#    - Create Twilio account at https://www.twilio.com/
#    - Register a WhatsApp Sender Phone Number in Twilio
#    - Get your Account SID and Auth Token from Twilio Console
#    - Set WHATSAPP_ENABLED=true
#    - Set WHATSAPP_SERVICE_TYPE=twilio
#    - Add TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN
#    - Add WHATSAPP_SENDER_NUMBER (with country code)
#
# 3. Admin WhatsApp Control:
#    - Go to Admin Dashboard → Events tab
#    - When creating/editing an event, toggle "Enable WhatsApp Notifications"
#    - Only events with WhatsApp enabled will send notifications
#
# 4. User Experience:
#    - Users will see WhatsApp checkbox in reminder modal for WhatsApp-enabled events
#    - Notifications sent on: event registration and when "Remind Me" is clicked
#    - Phone numbers formatted to include +91 country code for Indian numbers
